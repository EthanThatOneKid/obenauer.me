{
  "tasks": {
    "fmt": "deno fmt documents/",
    "sync-sitemap": "deno -A src/apps/sync-sitemap.ts",
    "scrape": {
      "command": "deno -A src/apps/scrape.ts",
      "description": "Syncs the sitemap and then scrapes the website into /documents/",
      "dependencies": ["sync-sitemap"]
    },
    "ingest": "deno -A --env src/apps/ingest.ts",
    "chat": "deno -A --env src/apps/chat.ts",
    "update": {
      "command": "deno task fmt",
      "description": "Complete update: sync, scrape, and format",
      "dependencies": ["scrape"]
    },
    "concepts": "deno -A --env src/apps/concepts.ts"
  },
  "imports": {
    "#/": "./src/",
    "@ai-sdk/google": "npm:@ai-sdk/google@^3.0.43",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@google/genai": "npm:@google/genai@^1.44.0",
    "ai": "npm:ai@^6.0.116",
    "zod": "npm:zod@^4.3.6",
    "@std/fs": "jsr:@std/fs@^1.0.23",
    "turndown": "npm:turndown@^7.2.2",
    "deno-dom": "jsr:@b-fuze/deno-dom@^0.1.56"
  }
}
